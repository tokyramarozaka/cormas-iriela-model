Class {
	#name : 'IMTileset',
	#superclass : 'CMTileset',
	#category : 'Iriela-Model',
	#package : 'Iriela-Model'
}

{ #category : 'icons' }
IMTileset class >> agent [

	<script: 'self agent inspect'>
	<tile>
	^ self tiles
		  at: #agent
		  ifAbsentPut: [ CMTile newFrom: self agentContents ]
]

{ #category : 'icons - contents' }
IMTileset class >> agentContents [

	^ ''
]

